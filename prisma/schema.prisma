// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SkillLevel {
  RK
  N_MINUS
  N
  N_PLUS
  S
  S_PLUS
  BG
  BG_PLUS
  P
}

enum SignUpStatus {
  CONFIRMED
  WAITLIST
  WITHDRAWN
}

enum SessionStatus {
  OPEN
  CLOSED
}

enum TimeSlot {
  EARLY // 1 ทุ่ม
  LATE // 2 ทุ่ม
}

model Session {
  id                   String           @id @default(cuid())
  date                 DateTime
  venue                String
  startTime            String
  maxPlayers           Int
  courtsEarly          Int              @default(3)
  courtsLate           Int              @default(3)
  courtConfigNote      String?
  remark               String?
  status               SessionStatus    @default(OPEN)
  closedAt             DateTime?
  registrationClosedAt DateTime?
  lateOpenedAt         DateTime?
  openCourts           String? // comma-separated open court numbers; null = auto by clock
  courtRateId          String?
  courtRate            CourtRate?       @relation(fields: [courtRateId], references: [id])
  courtHours           Float?
  shuttlecockTypeId    String?
  shuttlecockType      ShuttlecockType? @relation(fields: [shuttlecockTypeId], references: [id])
  shuttlecockQty       Int?
  courtCost            Int?
  shuttlecockCost      Int?
  totalCost            Int?
  // Frozen at close, like the prices above: what people were actually charged
  // must not move later when the club changes its current fee.
  feePerPerson         Int?
  createdAt            DateTime         @default(now())
  signUps              SignUp[]
  matches              Match[]
  pendingPairs         PendingPair[]
}

model SignUp {
  id             String        @id @default(cuid())
  sessionId      String
  session        Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name           String
  skillLevel     SkillLevel
  status         SignUpStatus  @default(CONFIRMED)
  timeSlot       TimeSlot      @default(EARLY) // where they actually play (block they're seated in)
  preferredSlot  TimeSlot      @default(EARLY) // which block they wanted (for queue-jump when 1 ทุ่ม opens)
  slotNumber     Int?
  checkedInAt    DateTime?
  checkedOutAt   DateTime? // when they left (per-person billing clock stops)
  addedByAdmin   Boolean       @default(false) // true = admin quick-add, false = self sign-up
  withdrawnAt    DateTime? // when the name was withdrawn (for the withdrawal log)
  createdAt      DateTime      @default(now())
  matchSlots     MatchPlayer[]
  fixedPartnerId String?       @unique
  fixedPartner   SignUp?       @relation("FixedPair", fields: [fixedPartnerId], references: [id])
  fixedPartnerOf SignUp?       @relation("FixedPair")
  athleteId      String?
  athlete        Athlete?      @relation(fields: [athleteId], references: [id])
}

model Athlete {
  id         String     @id @default(cuid())
  name       String     @unique
  skillLevel SkillLevel
  photoUrl   String? // small resized avatar stored as a data URL
  createdAt  DateTime   @default(now())
  // Cache version for /api/athletes/[id]/photo — bumping on update busts the URL.
  updatedAt  DateTime   @default(now()) @updatedAt
  signUps    SignUp[]
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String   @default("")
  imageUrl  String? // resized image stored as a data URL
  active    Boolean  @default(true)
  kind      String   @default("announcement") // "announcement" | "rule" (กฎก๊วน)
  createdAt DateTime @default(now())
  // Cache version for /api/announcements/[id]/image.
  updatedAt DateTime @default(now()) @updatedAt
}

model CourtRate {
  id           String    @id @default(cuid())
  name         String
  pricePerHour Int
  createdAt    DateTime  @default(now())
  sessions     Session[]
}

model ShuttlecockType {
  id            String    @id @default(cuid())
  name          String
  pricePerPiece Int
  createdAt     DateTime  @default(now())
  sessions      Session[]
}

model AppSettings {
  id             String   @id @default("singleton")
  qrImageDataUrl String?
  feePerPerson   Int      @default(5) // ค่าธรรมเนียมต่อคน (บาท) — บวกเข้าค่าคอร์ท ไม่แยกบรรทัด
  updatedAt      DateTime @updatedAt
}

model Match {
  id         String        @id @default(cuid())
  sessionId  String
  session    Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  round      Int
  court      Int
  createdAt  DateTime      @default(now())
  // Live court flow: set when the admin ends the game. winnerTeam is 1 or 2
  // (recorded for stats; both teams rotate out regardless of who won).
  finishedAt DateTime?
  winnerTeam Int?
  players    MatchPlayer[]
}

model MatchPlayer {
  id       String @id @default(cuid())
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  signUpId String
  signUp   SignUp @relation(fields: [signUpId], references: [id], onDelete: Cascade)
  team     Int
}

// A foursome the admin has set aside for the next court, persisted so it
// survives refreshes and other players finishing their games. Unlike Match,
// a PendingPair is not bound to a court yet — it may even include someone
// still playing right now (their id is just earmarked); it can only be
// promoted into a real Match once all four are actually free and a court is
// open (see /api/sessions/[id]/pending-pairs/[pendingId]/book).
model PendingPair {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  team1Ids  String[] // exactly 2 signUp ids
  team2Ids  String[] // exactly 2 signUp ids
  createdAt DateTime @default(now())
}
