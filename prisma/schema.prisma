// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SkillLevel {
  RK
  N_MINUS
  N
  N_PLUS
  S
  S_PLUS
  BG
  BG_PLUS
  P
}

enum SignUpStatus {
  CONFIRMED
  WAITLIST
  WITHDRAWN
}

enum SessionStatus {
  OPEN
  CLOSED
}

enum TimeSlot {
  EARLY // 1 ทุ่ม
  LATE // 2 ทุ่ม
}

model Session {
  id                   String           @id @default(cuid())
  date                 DateTime
  venue                String
  startTime            String
  maxPlayers           Int
  courtsEarly          Int              @default(3)
  courtsLate           Int              @default(3)
  courtConfigNote      String?
  remark               String?
  status               SessionStatus    @default(OPEN)
  closedAt             DateTime?
  registrationClosedAt DateTime?
  courtRateId          String?
  courtRate            CourtRate?       @relation(fields: [courtRateId], references: [id])
  courtHours           Float?
  shuttlecockTypeId    String?
  shuttlecockType      ShuttlecockType? @relation(fields: [shuttlecockTypeId], references: [id])
  shuttlecockQty       Int?
  courtCost            Int?
  shuttlecockCost      Int?
  totalCost            Int?
  createdAt            DateTime         @default(now())
  signUps              SignUp[]
  matches              Match[]
}

model SignUp {
  id             String        @id @default(cuid())
  sessionId      String
  session        Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name           String
  skillLevel     SkillLevel
  status         SignUpStatus  @default(CONFIRMED)
  timeSlot       TimeSlot      @default(EARLY) // where they actually play (block they're seated in)
  preferredSlot  TimeSlot      @default(EARLY) // which block they wanted (for queue-jump when 1 ทุ่ม opens)
  slotNumber     Int?
  checkedInAt    DateTime?
  createdAt      DateTime      @default(now())
  matchSlots     MatchPlayer[]
  fixedPartnerId String?       @unique
  fixedPartner   SignUp?       @relation("FixedPair", fields: [fixedPartnerId], references: [id])
  fixedPartnerOf SignUp?       @relation("FixedPair")
  athleteId      String?
  athlete        Athlete?      @relation(fields: [athleteId], references: [id])
}

model Athlete {
  id         String     @id @default(cuid())
  name       String     @unique
  skillLevel SkillLevel
  createdAt  DateTime   @default(now())
  signUps    SignUp[]
}

model CourtRate {
  id           String    @id @default(cuid())
  name         String
  pricePerHour Int
  createdAt    DateTime  @default(now())
  sessions     Session[]
}

model ShuttlecockType {
  id            String    @id @default(cuid())
  name          String
  pricePerPiece Int
  createdAt     DateTime  @default(now())
  sessions      Session[]
}

model AppSettings {
  id             String   @id @default("singleton")
  qrImageDataUrl String?
  updatedAt      DateTime @updatedAt
}

model Match {
  id         String        @id @default(cuid())
  sessionId  String
  session    Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  round      Int
  court      Int
  createdAt  DateTime      @default(now())
  // Live court flow: set when the admin ends the game. winnerTeam is 1 or 2
  // (recorded for stats; both teams rotate out regardless of who won).
  finishedAt DateTime?
  winnerTeam Int?
  players    MatchPlayer[]
}

model MatchPlayer {
  id       String @id @default(cuid())
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  signUpId String
  signUp   SignUp @relation(fields: [signUpId], references: [id], onDelete: Cascade)
  team     Int
}
